<launch>
    <arg name="map_file" default="/home/unitree/a1_maps/a1_lab.yaml" />
    <arg name="log_dir" default="/home/unitree/a1_nav_logs/latest" />
    <arg name="ip_address" default="192.168.11.1" />

    <!-- SLAMWAREはscan/odomだけ使う．mapは保存済みmapと衝突させない -->
    <node name="slamware_ros_sdk_server_node"
          pkg="slamware_ros_sdk"
          type="slamware_ros_sdk_server_node"
          output="screen">

        <param name="ip_address" value="$(arg ip_address)" />
        <param name="angle_compensate" value="true" />

        <!-- map->odomはAMCLに担当させる -->
        <param name="fixed_odom_map_tf" value="false" />

        <param name="robot_frame" value="base_link" />
        <param name="odom_frame" value="odom" />
        <param name="laser_frame" value="laser" />
        <param name="map_frame" value="map" />

        <param name="robot_pose_pub_period" value="0.05" />
        <param name="scan_pub_period" value="0.1" />
        <param name="map_pub_period" value="0.5" />
        <param name="path_pub_period" value="0.05" />

        <remap from="/slamware_ros_sdk_server_node/scan" to="/scan" />
        <remap from="/slamware_ros_sdk_server_node/odom" to="/odom" />
        <remap from="/slamware_ros_sdk_server_node/map" to="/slamware_map" />
        <remap from="map_metadata" to="/slamware_map_metadata" />
    </node>

    <node pkg="map_server"
          type="map_server"
          name="map_server"
          args="$(arg map_file)"
          output="screen" />

    <node name="basefoot2base"
          pkg="tf"
          type="static_transform_publisher"
          args="0 0 0 0 0 0 /base_footprint /base_link 100" />

    <node name="base2laser"
          pkg="tf"
          type="static_transform_publisher"
          args="0 0 0 0 0 0 /base_link /laser 100" />

    <node pkg="amcl"
          type="amcl"
          name="amcl"
          output="screen">

        <param name="odom_frame_id" value="odom" />
        <param name="base_frame_id" value="base_footprint" />
        <param name="global_frame_id" value="map" />

        <param name="use_map_topic" value="true" />
        <param name="first_map_only" value="true" />

        <param name="odom_model_type" value="omni" />

        <param name="min_particles" value="1000" />
        <param name="max_particles" value="4000" />

        <param name="update_min_d" value="0.05" />
        <param name="update_min_a" value="0.10" />

        <param name="laser_min_range" value="0.15" />
        <param name="laser_max_range" value="8.0" />
        <param name="laser_max_beams" value="80" />

        <param name="transform_tolerance" value="1.0" />

        <param name="alpha1" value="0.45" />
        <param name="alpha2" value="0.45" />
        <param name="alpha3" value="0.55" />
        <param name="alpha4" value="0.55" />
        <param name="alpha5" value="0.45" />
    </node>

    <node pkg="move_base"
          type="move_base"
          name="move_base"
          output="screen"
          clear_params="true">

        <remap from="cmd_vel" to="/cmd_vel_nav" />

        <rosparam file="$(find slam_planner)/params/move_base_teb_params.yaml"
                  command="load" />

        <rosparam file="$(find slam_planner)/params/costmap_common_params.yaml"
                  command="load"
                  ns="global_costmap" />

        <rosparam file="$(find slam_planner)/params/costmap_common_params.yaml"
                  command="load"
                  ns="local_costmap" />

        <rosparam file="$(find slam_planner)/params/global_costmap_params.yaml"
                  command="load" />

        <rosparam file="$(find slam_planner)/params/local_costmap_params.yaml"
                  command="load" />

        <rosparam file="$(find slam_planner)/params/teb_a1_params.yaml"
                  command="load" />
    </node>

    <node pkg="slam_planner"
          type="a1_lateral_guard_node.py"
          name="a1_lateral_guard_node"
          output="screen">

        <param name="max_vx" value="0.75" />
        <param name="max_vy" value="0.22" />
        <param name="max_wz" value="0.24" />

        <param name="min_walk_vx" value="0.45" />
        <param name="speed_lift_threshold" value="0.05" />

        <param name="accel_vx" value="0.30" />
        <param name="accel_vy" value="0.35" />
        <param name="accel_wz" value="0.25" />
        <param name="decel_vx" value="0.90" />

        <param name="k_lat" value="0.85" />
        <param name="max_lat_corr" value="0.20" />
        <param name="lat_sign" value="-1.0" />

        <param name="straight_wz_threshold" value="0.06" />
        <param name="enable_lateral_correction" value="true" />

        <param name="front_stop_dist" value="0.65" />
        <param name="front_slow_dist" value="1.00" />
        <param name="front_sector_deg" value="35.0" />

        <param name="goal_stop_radius" value="0.45" />
        <param name="goal_latch_radius" value="0.38" />

        <param name="cmd_timeout" value="0.35" />
    </node>

    <node pkg="slam_planner"
          type="base_controller_node"
          name="base_controller_node"
          output="screen" />

    <node pkg="rosbag"
          type="record"
          name="a1_nav_rosbag"
          output="screen"
          args="-O $(arg log_dir)/a1_nav.bag
                /tf
                /tf_static
                /map
                /scan
                /odom
                /amcl_pose
                /particlecloud
                /move_base_simple/goal
                /move_base/NavfnROS/plan
                /move_base/TebLocalPlannerROS/local_plan
                /move_base/local_costmap/costmap
                /move_base/global_costmap/costmap
                /cmd_vel_nav
                /cmd_vel
                /a1_nav_debug" />
</launch>
