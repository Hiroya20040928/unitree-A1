#!/usr/bin/env bash
set -Eeuo pipefail

GAIT="${1:-standing_trot}"
DURATION="${2:-120}"

WS="$HOME/legged_ws"

cd "$WS"
source /opt/ros/melodic/setup.bash
source devel/setup.bash

export ROBOT_TYPE=a1
export ROS_MASTER_URI=http://127.0.0.1:11311
export ROS_IP=127.0.0.1
unset ROS_HOSTNAME

/usr/bin/python - "$GAIT" "$DURATION" <<'PY'
import sys
import rospy
from ocs2_msgs.msg import mode_schedule, mpc_observation

gait = sys.argv[1]
duration = float(sys.argv[2])

GAITS = {
    "stance": {
        "switching": [0.0, 1.0],
        "modes": [15],
    },
    "standing_trot": {
        "switching": [0.0, 0.25, 0.30, 0.55, 0.60],
        "modes": [9, 15, 6, 15],
    },
    "standing_pace": {
        "switching": [0.0, 0.30, 0.35, 0.65, 0.70],
        "modes": [12, 15, 3, 15],
    },
}

if gait not in GAITS:
    raise SystemExit("unknown gait: {}. available: {}".format(gait, sorted(GAITS.keys())))

rospy.init_node("a1_gait_absolute_schedule_publisher", anonymous=True, disable_signals=True)

pub = rospy.Publisher("/legged_robot_mpc_mode_schedule", mode_schedule, queue_size=1)

print("[A1GAIT] waiting for /legged_robot_mpc_observation...")
obs = rospy.wait_for_message("/legged_robot_mpc_observation", mpc_observation, timeout=10.0)

now = float(obs.time)
start = now + 0.20

switching = GAITS[gait]["switching"]
modes_template = GAITS[gait]["modes"]
period = switching[-1]

cycles = int(duration / period) + 2

events = [start]
modes = []

for c in range(cycles):
    base = start + c * period
    for j, mode in enumerate(modes_template):
        modes.append(int(mode))
        events.append(base + switching[j + 1])

msg = mode_schedule()
msg.eventTimes = events
msg.modeSequence = modes

print("[A1GAIT] current observation time: {:.3f}".format(now))
print("[A1GAIT] gait: {}".format(gait))
print("[A1GAIT] start time: {:.3f}".format(start))
print("[A1GAIT] period: {:.3f}".format(period))
print("[A1GAIT] cycles: {}".format(cycles))
print("[A1GAIT] first eventTimes: {}".format(events[:8]))
print("[A1GAIT] first modeSequence: {}".format(modes[:8]))

rate = rospy.Rate(10)
for i in range(20):
    pub.publish(msg)
    rate.sleep()

print("[A1GAIT] published absolute mode schedule.")
PY
